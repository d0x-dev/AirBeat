import asyncio
import aiohttp
import sys

FALLBACK_API_URL = "https://shrutibots.site"
API_SOURCE = "https://pastebin.com/raw/rLsBhAQa"

YOUR_API_URL = None


async def load_api_url():
    global YOUR_API_URL
    try:
        async with aiohttp.ClientSession() as session:
            async with session.get(API_SOURCE, timeout=aiohttp.ClientTimeout(total=10)) as resp:
                if resp.status == 200:
                    YOUR_API_URL = (await resp.text()).strip()
                else:
                    YOUR_API_URL = FALLBACK_API_URL
    except Exception:
        YOUR_API_URL = FALLBACK_API_URL


def extract_video_id(link: str) -> str:
    if "v=" in link:
        return link.split("v=")[-1].split("&")[0]
    elif "youtu.be/" in link:
        return link.split("youtu.be/")[-1].split("?")[0]
    return link.strip()


async def get_stream_url(video_id: str, stream_type="video"):
    global YOUR_API_URL

    if not YOUR_API_URL:
        await load_api_url()

    if not YOUR_API_URL:
        print("❌ API not available")
        return None

    async with aiohttp.ClientSession() as session:
        try:
            # Step 1: Get download token
            async with session.get(
                f"{YOUR_API_URL}/download",
                params={"url": video_id, "type": stream_type},
                timeout=aiohttp.ClientTimeout(total=60)
            ) as resp:
                if resp.status != 200:
                    print("❌ Failed to get token")
                    return None

                data = await resp.json()
                token = data.get("download_token")

                if not token:
                    print("❌ No token received")
                    return None

                # Step 2: Build stream URL
                stream_url = f"{YOUR_API_URL}/stream/{video_id}?type={stream_type}&token={token}"
                return stream_url

        except Exception as e:
            print(f"❌ Error: {e}")
            return None


async def main():
    print("\n🎬 YouTube Stream URL Generator\n")

    link = input("Enter YouTube URL: ").strip()
    if not link:
        print("❌ No URL provided")
        return

    stream_choice = input("Type 'audio' for MP3 or 'video' for MP4 (default video): ").strip().lower()
    if stream_choice not in ["audio", "video"]:
        stream_choice = "video"

    video_id = extract_video_id(link)

    if len(video_id) < 3:
        print("❌ Invalid YouTube URL")
        return

    stream_url = await get_stream_url(video_id, stream_choice)

    if stream_url:
        print("\n✅ Stream URL Generated:\n")
        print(stream_url)
    else:
        print("❌ Could not generate stream URL")


if __name__ == "__main__":
    asyncio.run(main())
